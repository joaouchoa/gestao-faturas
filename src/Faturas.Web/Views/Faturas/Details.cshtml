@model FaturaDetailsViewModel
@{
    ViewData["Title"] = Model.Numero;
    var ptBR = new System.Globalization.CultureInfo("pt-BR");
    var aberta = Model.Status == "Aberta";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@Model.Numero</h2>
    <div class="d-flex gap-2">
        @if (aberta)
        {
            <form asp-action="Fechar" asp-route-id="@Model.Id" method="post" class="d-inline"
                  onsubmit="return confirm('Confirma o fechamento da fatura? Esta ação não pode ser desfeita.')">
                @Html.AntiForgeryToken()
                <button class="btn btn-warning">Fechar Fatura</button>
            </form>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">← Voltar</a>
    </div>
</div>

@if (TempData["Erro"] is string erro)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @erro
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Sucesso"] is string sucesso)
{
    <div class="alert alert-success alert-dismissible fade show">
        @sucesso
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mb-4">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Cliente</dt>
                    <dd class="col-sm-7">@Model.NomeCliente</dd>

                    <dt class="col-sm-5">Data de emissão</dt>
                    <dd class="col-sm-7">@Model.DataEmissao.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-5">Status</dt>
                    <dd class="col-sm-7">
                        <span class="badge @(aberta ? "bg-success" : "bg-secondary")">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-5">Total</dt>
                    <dd class="col-sm-7"><strong>@Model.ValorTotal.ToString("C", ptBR)</strong></dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<h4>Itens (@Model.Itens.Count)</h4>

@if (!Model.Itens.Any())
{
    <p class="text-muted">Nenhum item adicionado.</p>
}
else
{
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Descrição</th>
                <th class="text-center">Qtd</th>
                <th class="text-end">Valor Unit.</th>
                <th class="text-end">Total</th>
                <th>Justificativa</th>
                @if (aberta) { <th></th> }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Itens)
            {
                <tr>
                    <td>@item.Descricao</td>
                    <td class="text-center">@item.Quantidade</td>
                    <td class="text-end">@item.ValorUnitario.ToString("C", ptBR)</td>
                    <td class="text-end">@item.ValorTotalItem.ToString("C", ptBR)</td>
                    <td>@(item.Justificativa ?? "-")</td>
                    @if (aberta)
                    {
                        <td class="text-end">
                            <form asp-action="RemoveItem" method="post" class="d-inline"
                                  onsubmit="return confirm('Confirma a remoção do item?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="faturaId" value="@Model.Id" />
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remover</button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}

@if (aberta)
{
    <hr />
    <h5 class="mt-4">Adicionar Item</h5>
    @await Html.PartialAsync("_AddItem", Model.NovoItem)
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
