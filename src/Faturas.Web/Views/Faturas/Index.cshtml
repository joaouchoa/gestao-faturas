@model FaturaListViewModel
@{
    ViewData["Title"] = "Faturas";
    var ptBR         = new System.Globalization.CultureInfo("pt-BR");
    var filtro       = Model.Filtro;
    var paginaAtual  = filtro.Pagina;
    var totalPaginas = Model.TotalPaginas;
    int pgInicio     = Math.Max(1, paginaAtual - 2);
    int pgFim        = Math.Min(totalPaginas, paginaAtual + 2);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Faturas</h2>
    <a asp-action="Create" class="btn btn-primary">+ Nova Fatura</a>
</div>

<form method="get" class="card mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Cliente</label>
                <input type="text" name="cliente" value="@filtro.Cliente" class="form-control" placeholder="Nome do cliente" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Data inicial</label>
                <input type="date" name="dataInicial" value="@filtro.DataInicial?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Data final</label>
                <input type="date" name="dataFinal" value="@filtro.DataFinal?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">Todos</option>
                    <option value="Aberta"  selected="@(filtro.Status == "Aberta"  ? "selected" : null)">Aberta</option>
                    <option value="Fechada" selected="@(filtro.Status == "Fechada" ? "selected" : null)">Fechada</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary">Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
            </div>
        </div>
    </div>
</form>

@if (!Model.Faturas.Any())
{
    <div class="alert alert-info">Nenhuma fatura encontrada para os filtros selecionados.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Número</th>
                <th>Cliente</th>
                <th>Emissão</th>
                <th class="text-center">Itens</th>
                <th class="text-end">Total</th>
                <th class="text-center">Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in Model.Faturas)
            {
                <tr>
                    <td><strong>@f.Numero</strong></td>
                    <td>@f.NomeCliente</td>
                    <td>@f.DataEmissao.ToString("dd/MM/yyyy")</td>
                    <td class="text-center">@f.TotalItens</td>
                    <td class="text-end">@f.ValorTotal.ToString("C", ptBR)</td>
                    <td class="text-center">
                        <span class="badge @(f.Status == "Aberta" ? "bg-success" : "bg-secondary")">@f.Status</span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@f.Id" class="btn btn-sm btn-outline-primary">Ver detalhes</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <small class="text-muted">
            Total: <strong>@Model.TotalRegistros</strong> fatura(s) &mdash;
            Página <strong>@paginaAtual</strong> de <strong>@totalPaginas</strong>
        </small>

        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(paginaAtual <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-cliente="@filtro.Cliente"
                       asp-route-dataInicial="@filtro.DataInicial?.ToString("yyyy-MM-dd")"
                       asp-route-dataFinal="@filtro.DataFinal?.ToString("yyyy-MM-dd")"
                       asp-route-status="@filtro.Status"
                       asp-route-pagina="@(paginaAtual - 1)"
                       asp-route-tamanhoPagina="@filtro.TamanhoPagina">&laquo;</a>
                </li>

                @for (int p = pgInicio; p <= pgFim; p++)
                {
                    <li class="page-item @(p == paginaAtual ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-cliente="@filtro.Cliente"
                           asp-route-dataInicial="@filtro.DataInicial?.ToString("yyyy-MM-dd")"
                           asp-route-dataFinal="@filtro.DataFinal?.ToString("yyyy-MM-dd")"
                           asp-route-status="@filtro.Status"
                           asp-route-pagina="@p"
                           asp-route-tamanhoPagina="@filtro.TamanhoPagina">@p</a>
                    </li>
                }

                <li class="page-item @(paginaAtual >= totalPaginas ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-cliente="@filtro.Cliente"
                       asp-route-dataInicial="@filtro.DataInicial?.ToString("yyyy-MM-dd")"
                       asp-route-dataFinal="@filtro.DataFinal?.ToString("yyyy-MM-dd")"
                       asp-route-status="@filtro.Status"
                       asp-route-pagina="@(paginaAtual + 1)"
                       asp-route-tamanhoPagina="@filtro.TamanhoPagina">&raquo;</a>
                </li>
            </ul>
        </nav>

        <div class="d-flex align-items-center gap-2">
            <small class="text-muted text-nowrap">Por página:</small>
            <form method="get" class="d-flex gap-1">
                <input type="hidden" name="cliente"      value="@filtro.Cliente" />
                <input type="hidden" name="dataInicial"  value="@filtro.DataInicial?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="dataFinal"    value="@filtro.DataFinal?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="status"       value="@filtro.Status" />
                <input type="hidden" name="pagina"       value="1" />
                <select name="tamanhoPagina" class="form-select form-select-sm" style="width:80px" onchange="this.form.submit()">
                    @foreach (var op in new[] { 5, 10, 25, 50 })
                    {
                        <option value="@op" selected="@(filtro.TamanhoPagina == op ? "selected" : null)">@op</option>
                    }
                </select>
            </form>
        </div>
    </div>
}
